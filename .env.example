# 環境變數（複製為 .env.local 後填入真實值）
# ─────────────────────────────────────────────
# Supabase → Project Settings → API

# 公開（可進前端）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 僅 server / ETL（絕對不要加 NEXT_PUBLIC_、不要 commit）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 資料模式：auto | mock | snapshot | supabase
DATA_MODE=auto

# 可選：保護 POST /api/admin/migrate-snapshot
# MIGRATE_SECRET=your-random-secret

# Vercel Cron / 手動觸發 /api/cron/twse-daily
# Production 必填；本機未設時僅允許 localhost
CRON_SECRET=replace-with-long-random-string
