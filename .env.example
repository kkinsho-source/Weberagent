# 環境變數範例
# 複製為 .env.local 並填入你的 Supabase 專案值
# 取得位置：Supabase Studio → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 資料模式（Phase 2）：mock | snapshot | supabase
# 未設定預設走 snapshot（lib/data/twse_snapshot.json 真實行情）
# 接上 Supabase 後改為 supabase（見 supabase/README.md）
DATA_MODE=snapshot
